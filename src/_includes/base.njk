<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% if title %}{{ title }} — {% endif %}{{ site.title }}</title>
    <meta name="description" content="{{ description or site.description }}">
    <link rel="stylesheet" href="{{ '/assets/style.css' | url }}">
  </head>
  <body>
    <div class="page">
      <header class="site-header">
        <div class="site-title"><a href="{{ '/' | url }}">{{ site.title }}</a></div>
        <nav>
          <ul class="nav-list">
            {% for item in site.navigation %}
              <li><a href="{{ item.url | url }}">{{ item.title }}</a></li>
            {% endfor %}
          </ul>
        </nav>
      </header>

      <main class="content">
        {{ content | safe }}
      </main>

      <footer class="site-footer">
        <p>{{ site.title }} · <a href="mailto:{{ site.email }}">{{ site.email }}</a></p>
      </footer>
    </div>
  </body>
</html>
