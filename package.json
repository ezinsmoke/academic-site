{
  "name": "academic-site-eleventy",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "npx @11ty/eleventy --serve",
    "build": "npx @11ty/eleventy",
    "build:pages": "npx @11ty/eleventy --pathprefix=/academic-site/ && touch _site/.nojekyll",
    "deploy": "npm run build:pages && gh-pages -d _site"
  },
  "dependencies": {
    "@11ty/eleventy": "^3.1.5"
  },
  "devDependencies": {
    "gh-pages": "^6.3.0"
  }
}
